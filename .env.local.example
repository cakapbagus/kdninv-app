# ─── Neon PostgreSQL ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://username:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── PWA ──────────────────────────────────────────────────────────────────────
# Generate in terminal: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log('PUBLIC:',k.publicKey,'\\nPRIVATE:',k.privateKey)"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@example.com

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA   (always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA  (always passes)
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ─── WEBAUTHN──────────────────────────────────────────────────────────────────
# Domain (without https://, without port)
# production: your-website.vercel.app
# local:      localhost
WEBAUTHN_RP_ID=localhost

# Origin lengkap dengan https
# production: your-website.vercel.app
# local:      http://localhost:3000
WEBAUTHN_ORIGIN=your-website.vercel.app

# Web app name displays on fingerprint dialog
WEBAUTHN_RP_NAME=web-title

# ─── Next.js ──────────────────────────────────────────────────────────────────
# Change value to 'production' for production
NODE_ENV=development
